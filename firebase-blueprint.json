{
  "entities": {
    "blog_posts": {
      "title": "Blog Post",
      "description": "Artigos do blog da agência ou dos clientes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "coverImage": { "type": "string" },
        "status": { "type": "string", "enum": ["Rascunho", "Planejado", "Aguardando Aprovação", "Publicado"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "category"]
    },
    "blog_categories": {
      "title": "Blog Category",
      "description": "Categorias para organizar os artigos do blog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "isProtected": { "type": "boolean", "description": "Se true, não pode ser deletada (ex: Geral)" }
      },
      "required": ["name", "slug"]
    },
    "clients": {
      "title": "Client",
      "description": "Clientes da agência",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "clientEmail": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "billingDay": { "type": "string" },
        "contractStart": { "type": "string" },
        "monthlyPosts": { "type": "number" },
        "monthlyBacklinks": { "type": "number" },
        "active": { "type": "boolean" },
        "agencyUid": { "type": "string" }
      },
      "required": ["name", "clientEmail"]
    },
    "backlinks": {
      "title": "Backlink",
      "description": "Registros de link building",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "targetUrl": { "type": "string" },
        "anchor": { "type": "string" },
        "status": { "type": "string", "enum": ["Rascunho", "Planejado", "Publicado"] },
        "publishedUrl": { "type": "string" },
        "targetMonth": { "type": "string" },
        "agencyUid": { "type": "string" }
      },
      "required": ["title", "clientName", "targetUrl"]
    }
  },
  "firestore": {
    "blog_posts": {
      "schema": "blog_posts",
      "description": "Coleção principal de artigos"
    },
    "blog_categories": {
      "schema": "blog_categories",
      "description": "Coleção de categorias gerenciáveis"
    },
    "clients": {
      "schema": "clients",
      "description": "Coleção de clientes da agência"
    },
    "backlinks": {
      "schema": "backlinks",
      "description": "Coleção de registros de link building"
    }
  }
}
