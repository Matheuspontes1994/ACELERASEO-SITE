rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function agencyOwns(agencyUid) {
      return isSignedIn() && request.auth.uid == agencyUid;
    }

    function isClient(data) {
      return isSignedIn() && (
        request.auth.token.email == data.clientEmail ||
        request.auth.token.email == data.websiteUrl
      );
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (agencyOwns(resource.data.agencyUid) || isClient(resource.data));
      allow write: if isSignedIn() && (agencyOwns(request.resource.data.agencyUid) || agencyOwns(resource.data.agencyUid));
    }

    match /keyword_universe/{id} {
      allow read: if isSignedIn() && (agencyOwns(resource.data.agencyUid) || isClient(resource.data));
      allow write: if isSignedIn() && agencyOwns(request.resource.data.agencyUid);
    }

    match /blog_posts/{id} {
      allow read: if isSignedIn() && (agencyOwns(resource.data.agencyUid) || isClient(resource.data));
      allow write: if isSignedIn() && agencyOwns(request.resource.data.agencyUid);
    }

    match /backlinks/{id} {
      allow read: if isSignedIn() && (agencyOwns(resource.data.agencyUid) || isClient(resource.data));
      allow write: if isSignedIn() && agencyOwns(request.resource.data.agencyUid);
    }

    match /seo_pages/{id} {
      allow read: if isSignedIn() && (agencyOwns(resource.data.agencyUid) || isClient(resource.data));
      allow write: if isSignedIn() && agencyOwns(request.resource.data.agencyUid);
    }
  }
}
