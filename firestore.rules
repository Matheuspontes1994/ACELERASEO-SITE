rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'matheuspontes290594@gmail.com' || 
        request.auth.token.email == 'aceleraseo@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Helpers ---
    function isValidContact(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 5 && data.email.size() <= 254 && data.email.matches('.*@.*\\..*') &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt is timestamp;
    }
    
    function isValidAuditLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() > 5 && data.phone.size() <= 20 &&
             data.url is string && data.url.size() > 5 && data.url.size() <= 2048 &&
             data.createdAt is timestamp;
    }
    
    function isValidSeoPage(data) {
      return data.url is string && data.url.size() > 5 &&
             data.title is string && data.title.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidStatusUpdate(incoming, existing) {
      return incoming.diff(existing).affectedKeys().hasOnly(['status', 'clientComment', 'updatedAt']);
    }

    // --- Global Safety Net ---
    match /{document=**} { allow read, write: if false; }

    // --- Collections ---

    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContact(incoming());
      allow read, update, delete: if isAdmin();
    }
    
    match /audit_leads/{leadId} {
      allow create: if isValidId(leadId) && isValidAuditLead(incoming());
      allow read, update, delete: if isAdmin();
    }
    
    match /seo_pages/{pageId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || (incoming().agencyUid == existing().agencyUid));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.uid || request.auth.token.email == resource.data.clientEmail);
      allow create: if isSignedIn() && (isAdmin() || request.auth.token.email == incoming().clientEmail);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == existing().uid && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'clientEmail', 'websiteUrl', 'logoUrl', 'updatedAt'])) ||
        (request.auth.token.email == existing().clientEmail && incoming().uid == request.auth.uid)
      );
      allow delete: if isAdmin();
    }
    
    match /blog_posts/{postId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.token.email == resource.data.clientEmail || request.auth.uid == resource.data.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        (request.auth.token.email == existing().clientEmail || request.auth.uid == existing().uid) && 
        isValidStatusUpdate(incoming(), existing())
      );
      allow delete: if isAdmin();
    }
    
    match /backlinks/{backlinkId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.token.email == resource.data.clientEmail || request.auth.uid == resource.data.uid);
      allow write: if isAdmin();
    }
  
    match /keyword_universe/{keywordId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.token.email == resource.data.clientEmail || request.auth.uid == resource.data.uid);
      allow write: if isAdmin();
    }
  }
}
